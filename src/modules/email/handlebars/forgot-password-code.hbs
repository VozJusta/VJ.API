<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="pt-BR">
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  <meta name="x-apple-disable-message-reformatting" />
  <title>Recuperação de senha - Voz Justa</title>
</head>

<body style="background-color: #ffffff; margin: 0; padding: 0;">
  <table border="0" width="100%" cellpadding="0" cellspacing="0" role="presentation" align="center">
    <tbody>
      <tr>
        <td align="center" style="background-color: #ffffff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
          
          <table align="center" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" style="max-width: 600px; margin: 20px auto; background-color: #eeeeee; padding: 20px;">
            <tbody>
              <tr>
                <td>
                  
                  <table align="center" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" style="background-color: #ffffff;">
                    <tbody>
                      <tr>
                        <td align="center" style="background-color: #080E1C; padding: 30px 0;">
                          <img alt="Voz Justa Logo" 
                               src="https://vozjusta.com.br/email-provider/logo-name.png" 
                               width="120" 
                               style="display: block; border: none; outline: none; text-decoration: none;" />
                        </td>
                      </tr>

                      <tr>
                        <td style="padding: 40px 35px;">
                          <h1 style="color: #333333; font-size: 24px; font-weight: 700; margin: 0 0 20px 0; text-align: center;">
                            Recuperação de senha
                          </h1>
                          <p style="font-size: 15px; line-height: 24px; color: #333333; text-align: center; margin: 0 0 30px 0;">
                            Recebemos um pedido para alterar a senha da sua conta.
                            Use o codigo abaixo para continuar.
                            <br /><br />
                            Se você não solicitou a recuperação, pode ignorar esta mensagem.
                          </p>

                          <table align="center" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation">
                            <tbody>
                              <tr>
                                <td align="center">
                                  <p style="font-size: 14px; color: #666666; margin: 0; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">
                                    Código de recuperação
                                  </p>
                                  <p style="font-size: 42px; line-height: 42px; color: #080E1C; margin: 15px 0; font-weight: 800; letter-spacing: 5px;">
                                    {{code}}
                                  </p>
                                  <p style="font-size: 13px; color: #999999; margin: 0;">
                                    (Esse código é válido por 15 minutos)
                                  </p>
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </td>
                      </tr>
                    </tbody>
                  </table>

                  <table align="center" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation">
                    <tbody>
                      <tr>
                        <td align="center" style="padding: 30px 20px; color: #888888; font-size: 12px; line-height: 18px; text-align: center;">
                          <p style="margin: 0 0 10px 0;">
                            © 2026 Voz Justa. Todos os direitos reservados.
                          </p>
                          <p style="margin: 0;">
                            Esta é uma mensagem automática, por favor não responda a este e-mail. 
                            Confira nossa <a href="https://vozjusta.com.br/privacidade" style="color: #080E1C; text-decoration: underline;">Política de Privacidade</a>.
                          </p>
                        </td>
                      </tr>
                    </tbody>
                  </table>

                </td>
              </tr>
            </tbody>
          </table>
        </td>
      </tr>
    </tbody>
  </table>
