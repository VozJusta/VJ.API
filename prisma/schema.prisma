// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Citizen {
  id                 String             @id @default(uuid())
  full_name          String
  cpf                String?            @unique
  cnpj               String?            @unique
  stripe_customer_id String?            @unique
  phone              String?            @unique
  email              String             @unique
  session_id         String             @default(uuid())
  subscription       Subscription?
  report             Report[]
  simulation         Simulation[]
  simulation_report  SimulationReport[]
  password           String?
  created_at         DateTime           @default(now())
  validationCodes    ValidationCode[]
  cases              Case[]
  caseRequests       CaseRequest[]
  notifications      Notification[]
}

model Lawyer {
  id                 String           @id @default(uuid())
  stripe_customer_id String?          @unique
  full_name          String
  bio                String?
  cpf                String?          @unique
  avatar_image       String?
  rating             Decimal?         @default(0)
  specialization     Specialization?
  lawyer_status      LawyerStatus     @default(Pending)
  oab_number         String?
  oab_state          OabState?
  phone              String?          @unique
  email              String           @unique
  session_id         String           @default(uuid())
  password           String?
  subscription       Subscription?
  report             Report[]
  created_at         DateTime         @default(now())
  validationCodes    ValidationCode[]
  cases              Case[]
  caseRequests       CaseRequest[]
  notifications      Notification[]
}

model Plan {
  id               String         @id @default(uuid())
  name             String
  stripe_price_id  String         @unique @default(uuid())
  type             PlanType       @default(FREE)
  billing_type     BillingType
  max_interviews   Int
  max_simulation   Int
  has_ia_petitions Boolean        @default(false)
  has_analytics    Boolean        @default(false)
  subscriptions    Subscription[]
}

model Subscription {
  id                     String             @id @default(uuid())
  stripe_subscription_id String             @unique @default(uuid())
  subscription_status    SubscriptionStatus
  citizen                Citizen?           @relation(fields: [citizen_id], references: [id])
  lawyer                 Lawyer?            @relation(fields: [lawyer_id], references: [id])
  citizen_id             String?            @unique
  lawyer_id              String?            @unique
  planId                 String
  plan                   Plan               @relation(fields: [planId], references: [id])
  interviews_used        Int                @default(0)
  simulations_used       Int                @default(0)
  leads_used             Int                @default(0)
  current_period_start   DateTime           @default(now())
  current_period_end     DateTime
}

model Report {
  id                     String         @id @default(uuid())
  transcription          String
  normalized_text        String
  legal_analysis         String
  simplified_explanation String
  category_detected      Specialization
  confidence_score       Float?
  citizen_id             String
  lawyer_id              String?
  lawyer                 Lawyer?        @relation(fields: [lawyer_id], references: [id])
  citizen                Citizen        @relation(fields: [citizen_id], references: [id])
  evidence               Evidence[]
  ai_versions            AiResponse[]
  created_at             DateTime       @default(now())
  ragContexts            RagContext[]
  simulations            Simulation[]
  case                   Case           @relation(fields: [caseId], references: [id])
  caseId                 String
}

model Case {
  id            String         @id @default(uuid())
  citizen_id    String
  lawyer_id     String?
  citizen       Citizen        @relation(fields: [citizen_id], references: [id])
  lawyer        Lawyer?        @relation(fields: [lawyer_id], references: [id])
  title         String
  status        Status         @default(Pending)
  reports       Report[]
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  conversations Conversation[]
  caseRequests  CaseRequest[]
}

model CaseRequest {
  id String @id @default(uuid())

  case_id String
  case    Case   @relation(fields: [case_id], references: [id])

  citizen_id String
  citizen    Citizen @relation(fields: [citizen_id], references: [id])

  lawyer_id String
  lawyer    Lawyer @relation(fields: [lawyer_id], references: [id])

  status Status @default(Pending)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([case_id, lawyer_id])
}

model Conversation {
  id         String    @id @default(uuid())
  case_id    String
  case       Case      @relation(fields: [case_id], references: [id])
  messages   Message[]
  is_closed  Boolean   @default(false)
  created_at DateTime  @default(now())
}

model Message {
  id              String       @id @default(uuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id])
  role            MessageRole
  content         String
  created_at      DateTime     @default(now())
}

model AiResponse {
  id          String   @id @default(uuid())
  report_id   String
  report      Report   @relation(fields: [report_id], references: [id])
  model       String
  provider    String
  prompt      String
  response    String
  tokens_used Int?
  latency_ms  Int?
  created_at  DateTime @default(now())
}

model RagContext {
  id         String   @id @default(uuid())
  report_id  String
  report     Report   @relation(fields: [report_id], references: [id])
  source     String
  content    String
  score      Float
  created_at DateTime @default(now())
}

model ValidationCode {
  id         String   @id @default(uuid())
  type       Types
  citizen_id String?
  lawyer_id  String?
  citizen    Citizen? @relation(fields: [citizen_id], references: [id])
  lawyer     Lawyer?  @relation(fields: [lawyer_id], references: [id])
  code       String
  validated  Boolean  @default(false)
  email      String
  expired    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Simulation {
  id                String            @id @default(uuid())
  citizen_id        String
  citizen           Citizen           @relation(fields: [citizen_id], references: [id])
  report_id         String?
  report            Report?           @relation(fields: [report_id], references: [id])
  personality       Personality
  transcription     String?
  score_feedback    String?
  status            SimStatus?        @default(Waiting)
  started_at        DateTime          @default(now())
  ended_at          DateTime?
  duration_secs     Int?
  turns             SimulationTurn[]
  simulation_report SimulationReport?
}

model SimulationTurn {
  id            String     @id @default(uuid())
  simulation_id String
  simulation    Simulation @relation(fields: [simulation_id], references: [id])
  role          TurnRole
  content       String
  audio_url     String?
  created_at    DateTime   @default(now())
}

model SimulationReport {
  id              String      @id @default(uuid())
  simulation_id   String      @unique
  simulation      Simulation  @relation(fields: [simulation_id], references: [id])
  user_id         String
  user            Citizen     @relation(fields: [user_id], references: [id])
  full_transcript Json
  score           Int?
  strengths       String[]
  weaknesses      String[]
  metrics_json    Json?
  duration_secs   Int?
  personality     Personality
  created_at      DateTime    @default(now())
}

model Evidence {
  id          String @id @default(uuid())
  report_id   String
  report      Report @relation(fields: [report_id], references: [id])
  file_url    String
  ocr_content String
  embedding   Json?
}

model Notification {
  id         String           @id @default(uuid())
  title      String
  body       String
  type       NotificationType
  is_read    Boolean          @default(false)
  metadata   Json?
  citizen_id String?
  lawyer_id  String?
  citizen    Citizen?         @relation(fields: [citizen_id], references: [id])
  lawyer     Lawyer?          @relation(fields: [lawyer_id], references: [id])
  created_at DateTime         @default(now())
  read_at    DateTime?

  @@index([citizen_id, created_at])
  @@index([lawyer_id, created_at])
}

enum Specialization {
  Administrative
  Customs
  Legal_support
  Aviation
  Agrarian
  Environmental
  Arbitration
  Copyright
  Banking_and_financial
  Biotechnology
  Civil
  Commercial
  International_trade
  Competition
  Constitutional
  Consumer
  Commercial_contracts
  Sports
  Water
  Third_sector
  Economic
  Electoral
  Corporate_criminal
  Energy
  Bankruptcy
  Family
  Mergers
  Real_estate
  Import_and_export
  Infrastructure
  International
  Internet_and_ECommerce
  Maritime
  Capital_markets
  Mining
  Financial_operations
  Criminal
  Oil_and_gas
  Social_security
  Project_finance
  Intellectual_property
  Corporate_restructuring
  Regulatory
  Health_and_sanitary
  Insurance
  Labor_union
  Corporate
  Telecommunications
  Labor_and_employment
  Tax
}

enum LawyerStatus {
  Pending
  Verified
  Suspended
  Rejected
}

enum PlanType {
  MEDIUM
  PREMIUM
  FREE
}

enum MessageRole {
  User
  Assistant
}

enum BillingType {
  Monthly
  One_Time
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  unpaid
  inactive
}

enum Status {
  Accepted
  Refused
  Pending
}

enum Types {
  Email
  SMS
}

enum TurnRole {
  User
  Ai
}

enum SimStatus {
  Waiting
  InProgress
  Completed
  TimedOut
}

enum Personality {
  Calm
  Agressive
  Impartial
  Empathetic
  Pragmatic
  Researcher
}

enum OabState {
  AC
  AL
  AP
  AM
  BA
  CE
  DF
  ES
  GO
  MA
  MT
  MS
  MG
  PA
  PB
  PR
  PE
  PI
  RJ
  RN
  RS
  RO
  RR
  SC
  SP
  SE
  TO
}

enum NotificationType {
  REQUEST_SENT
  REQUEST_ACCEPTED
  REQUEST_REFUSED
}
